# コピーして .env として使う:  cp .env.example .env
# .env は .gitignore 済み。値は各自入手して埋める。

# --- LLM プロバイダ -----------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- データストア（docker-compose のデフォルトに合わせてある）---------
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://clipmind:clipmind@localhost:5432/clipmind

# --- 観測性（任意。設定が無くてもアプリは動く）-------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=clipmind
